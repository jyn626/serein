<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="Win98ButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#D4D0C8"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">

                    <Border x:Name="OuterDark"
                            BorderBrush="#202020"
                            BorderThickness="0,0,1,1"
                        >
                        <Border x:Name="InnerDark"
                                BorderBrush="#40505050"
                                BorderThickness="0,0,1,1">

                                <Border x:Name="InnerLight"
                                        BorderBrush="#90FFFFFF"
                                        BorderThickness="2,2,0,0"
                                        Background="{TemplateBinding Background}"
                                        Padding="2">

                                    <ContentPresenter x:Name="contentPresenter"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>

                                </Border>
                        </Border>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="InnerDark"
                                Property="Background"
                                Value="#505050"/>
                        </Trigger>


                        <Trigger Property="IsPressed" Value="True">

                            <Setter TargetName="InnerLight"
                                    Property="BorderBrush"
                                    Value="#202020"/>

                            <Setter TargetName="OuterDark"
                                    Property="BorderBrush"
                                    Value="#FFFFFF"/>


                            <Setter TargetName="InnerDark"
                                    Property="BorderBrush"
                                    Value="#DFDFDF"/>
                            
                            <Setter TargetName="contentPresenter"
                                    Property="Margin"
                                    Value="1,1,0,0"/>

                        </Trigger>
                        
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>

</ResourceDictionary>